# ═══════════════════════════════════════════════════════════════════════
# MPC Wallet — Local Infrastructure Configuration
#
# Copy this file to .env and adjust as needed:
#   cp infra/local/.env.example infra/local/.env
#
# All values have sensible defaults. Override only what you need.
# ═══════════════════════════════════════════════════════════════════════

# ── Docker Image Versions ─────────────────────────────────────────────
VAULT_IMAGE=hashicorp/vault:1.15
REDIS_IMAGE=redis:7-alpine
NATS_IMAGE=nats:2.10-alpine

# ── Ports ─────────────────────────────────────────────────────────────
# Change if these conflict with existing services on your machine.
VAULT_PORT=8200
REDIS_PORT=6379
NATS_CLIENT_PORT=4222
NATS_MONITOR_PORT=8222
GATEWAY_PORT=3000

# ── Vault ─────────────────────────────────────────────────────────────
VAULT_DEV_TOKEN=dev-root-token
VAULT_MOUNT=secret
VAULT_SECRETS_PATH=mpc-wallet/gateway
VAULT_APPROLE_NAME=mpc-gateway
VAULT_POLICY_NAME=mpc-gateway

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_MAXMEMORY=128mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# ── NATS ──────────────────────────────────────────────────────────────
NATS_MAX_PAYLOAD=1048576

# ── Gateway ───────────────────────────────────────────────────────────
NETWORK=testnet
SESSION_BACKEND=redis
SESSION_TTL=3600
RATE_LIMIT_RPS=100
RUST_LOG=mpc_wallet_api=info

# ── Build ─────────────────────────────────────────────────────────────
# Set to "debug" for faster builds (no optimizations).
CARGO_PROFILE=release
